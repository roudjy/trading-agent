# -------------------------
# Python
# -------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# -------------------------
# Existing project ignores (KEEP)
# -------------------------
.env
.env.*
.tmp/
tests_tmp/

logs/
reports/
research/provenance/
state/

# -------------------------
# Secrets / runtime config (v3.15.15.12.0 — Emergency Containment)
# -------------------------
config/config.yaml
# config/config.template.yaml IS tracked (schema-of-record)

# -------------------------
# Build provenance (runtime; schema is tracked)
# -------------------------
artifacts/build_provenance-*.json
# artifacts/build_provenance.schema.json IS tracked

# -------------------------
# Data layer (CRITICAL WHITELISTING)
# -------------------------
data/*
!data/__init__.py
!data/contracts.py
!data/repository.py
!data/adapters/
