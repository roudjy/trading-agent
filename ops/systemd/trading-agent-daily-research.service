[Unit]
Description=JvR Trading Agent — autonomous campaign operating layer tick (v3.15.2)
Documentation=https://github.com/roudjy/trading-agent docs/adr/ADR-011-v3.10-architecture.md
# Only fire once the dashboard container is up. The unit fails loudly and
# the journal captures it when the container is not running.
After=docker.service network-online.target

[Service]
Type=oneshot
# v3.15.2: each tick runs the campaign operating layer inside the existing
# jvr_dashboard container. The launcher is a single-tick CLI: it loads
# artifacts, runs the pure decide() function, applies the chosen action
# under a queue file lock, and exits. Cron fires it hourly; preset
# selection, follow-ups, freezes, and budget are now policy-driven, not
# hand-picked. Presets with excluded_from_daily_scheduler=True remain
# excluded by the policy engine (ADR-011 §5 honoured end-to-end).
ExecStart=/usr/bin/docker exec jvr_dashboard python -m research.campaign_launcher
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
